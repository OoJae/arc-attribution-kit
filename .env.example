# arc-attribution-kit, environment template.
# Copy to .env.local and fill in.

# ---------- Arc testnet ----------
# Default works without override.
ARC_RPC_URL=https://rpc.testnet.arc.network

# Operator EOA (contract owner). Generate with `openssl rand -hex 32` and
# fund with testnet USDC + tiny Arc gas. This wallet:
#  - Deploys the AttributionEscrow contract.
#  - Calls registerSubject + creditFees.
#  - Initiates CCTP sweeps (if used) from Polygon Amoy.
OPERATOR_PRIVATE_KEY=

# Set after deploying via `npm run deploy`.
ATTRIBUTION_ESCROW_ADDRESS=

# Platform fee in basis points used at deploy time (2000 = 20%, 1000 = 10%, 0 = none).
PLATFORM_FEE_BPS=2000

# Gate the /api/credit endpoint so only an operator with this key can credit fees.
OPERATOR_API_KEY=

# ---------- Circle Modular Wallets (passkey + paymaster) ----------
# From https://console.circle.com/apikeys
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
# Client-side WebAuthn transport (public).
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=

# ---------- Polygon Amoy (only for optional CCTP sweep) ----------
POLYGON_RPC_URL=
# Set to "1" once the operator EOA has testnet USDC on Polygon Amoy.
# When "0", the sweep handler returns a mocked 4-event sequence.
CCTP_ENABLED=0
